@model TrustGuard.Web.Models.RegisterViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-header text-dark text-center" style="background-color: #8ab4f8;">
                    <h4 class="mb-0 fw-bold">Створення акаунту</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post" id="regForm">
                        @* Сюди прилетять помилки з сервера, якщо пароль все одно не підійде *@
                        <div asp-validation-summary="All" class="text-danger small"></div>

                        <div class="mb-3">
                            <label class="form-label">Повне ім'я</label>
                            <input asp-for="FullName" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" id="emailField" class="form-control" placeholder="user@example.com" />
                            <small id="emailError" class="text-danger"></small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Пароль</label>
                            <input asp-for="Password" type="password" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Підтвердіть пароль</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        </div>

                        <button type="submit" id="submitBtn" class="btn w-100 text-dark fw-bold mb-3" style="background-color: #8ab4f8;">Зареєструватися</button>

                        <!-- НОВИЙ БЛОК: Посилання на сторінку входу -->
                        <div class="text-center">
                            <span class="small text-muted">Вже маєте акаунт?</span>
                            <a asp-action="Login" class="text-decoration-none small fw-bold">Увійти</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        $(document).ready(function () {

        // Тільки перевірка пошти

        $('#emailField').on('input', function () {

        const email = $(this).val();

        const regex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;



        if (email.length > 0 && !regex.test(email)) {

        $('#emailError').text('Формат пошти невірний');

        $(this).addClass('is-invalid');

        } else {

        $('#emailError').text('');

        $(this).removeClass('is-invalid');

        }

        });

        });

    </script>
}