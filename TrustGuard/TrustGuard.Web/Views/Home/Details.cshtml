@model TrustGuard.Domain.Entities.NewsCheck

@{
    ViewData["Title"] = "Деталі перевірки";
    
    var isFake = Model.Verdict == TrustGuard.Domain.Entities.Verdict.Fake;
    var isReal = Model.Verdict == TrustGuard.Domain.Entities.Verdict.Real;
    var colorClass = isFake ? "text-danger" : (isReal ? "text-success" : "text-warning");
    var iconClass = isFake ? "bi-shield-x" : (isReal ? "bi-shield-check" : "bi-shield-exclamation");
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Назад до Дашборду
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card border-dark rounded-0 shadow-none h-100">
                <div class="card-header border-dark bg-light rounded-0">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-file-text me-2"></i>Проаналізований контент</h5>
                </div>
                <div class="card-body">
                    <p style="white-space: pre-wrap; word-break: break-word;">@Model.RawContent</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="border border-dark d-flex flex-column align-items-center justify-content-center bg-white h-100 p-4" style="min-height: 400px;">
                
                <i class="bi @iconClass @colorClass mb-3" style="font-size: 5rem;"></i>
                <h2 class="@colorClass fw-bold text-uppercase">@Model.Verdict</h2>
                <h5 class="text-muted mt-2 mb-5">Впевненість: @(Math.Round(Model.ConfidenceScore * 100))%</h5>

                <div class="w-100 pt-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Дата перевірки:</span>
                        <span class="fw-bold small">@Model.CheckDate.ToString("dd.MM.yyyy HH:mm:ss")</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>