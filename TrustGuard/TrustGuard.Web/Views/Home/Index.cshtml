@using TrustGuard.Application.Models
@model DashboardStatsDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2 class="fw-bold">Ваш інтелектуальний щит у цифровому світі</h2>
    <p class="text-muted">TrustGuard використовує передові методи машинного навчання для автоматичного виявлення фейкових новин. Один інтерфейс — повний контроль над безпекою ваших даних.</p>

    <div class="row mt-5 mb-5 align-items-stretch">
        
        <div class="col-lg-6">
            <h5 class="mb-3 fw-bold">Статистика попередніх даних</h5>
            <div class="row g-3 h-75">
                <div class="col-md-4">
                    <div class="card p-3 shadow-none text-center h-100 border-dark rounded-0 d-flex justify-content-center">
                        <small class="text-dark d-block mb-2">Total Checks</small>
                        <span class="fs-4 text-dark">@Model.TotalChecks</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card p-3 shadow-none text-center h-100 border-dark rounded-0 d-flex justify-content-center">
                        <small class="text-dark d-block mb-2">Fraud Detected (%)</small>
                        <span class="fs-4 text-dark">@Model.FakePercentage%</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card p-3 shadow-none text-center h-100 border-dark rounded-0 d-flex justify-content-center">
                        <small class="text-dark d-block mb-2">Safety Score</small>
                        <span class="fs-4 text-dark">@Model.SafetyScore</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mt-4 mt-lg-0">
            <h5 class="mb-3 fw-bold">Графік перевірок</h5> <div class="card shadow-none h-75 border-dark rounded-0 d-flex align-items-center justify-content-center">
            <span class="text-muted"><i class="bi bi-bar-chart-fill me-2"></i>Місце для графіка (TASK 9)</span>
        </div>
    </div>

</div>
    
<div class="d-flex justify-content-between align-items-center mt-5 mb-3">
    <h5 class="fw-bold">Історія попередніх перевірок</h5>
</div>

<div class="table-responsive border border-dark bg-white">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-secondary border-dark">
            <tr>
                <th scope="col" class="text-center border-dark">Type</th>
                <th scope="col" class="border-dark">Date/Time</th>
                <th scope="col" class="border-dark">Object Analysis</th>
                <th scope="col" class="border-dark">Verdict</th>
                <th scope="col" class="border-dark">Confidence</th>
                <th scope="col" class="border-dark">Details</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RecentHistory != null && Model.RecentHistory.Any())
            {
                TimeZoneInfo ukraineTimeZone;
                try
                {
                    ukraineTimeZone = TimeZoneInfo.FindSystemTimeZoneById("FLE Standard Time");
                }
                catch
                {
                    ukraineTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Europe/Kyiv");
                }

                foreach (var item in Model.RecentHistory)
                {
                    var isFake = item.Verdict == TrustGuard.Domain.Entities.Verdict.Fake;
                    var isReal = item.Verdict == TrustGuard.Domain.Entities.Verdict.Real;
                    var badgeClass = isFake ? "bg-danger" : (isReal ? "bg-success" : "bg-warning text-dark");
                    var snippet = item.RawContent.Length > 40 ? item.RawContent.Substring(0, 40) + "..." : item.RawContent;

                    DateTime localTime = TimeZoneInfo.ConvertTimeFromUtc(item.CheckDate, ukraineTimeZone);

                    <tr>
                        <td class="text-center border-dark"><i class="bi bi-file-earmark-text fs-5"></i></td>
                            
                        <td class="text-nowrap border-dark">@localTime.ToString("dd.MM.yyyy HH:mm")</td>
                            
                        <td class="border-dark">"@snippet"</td>
                        <td class="border-dark"><span class="badge @badgeClass rounded-pill">@item.Verdict.ToString().ToUpper()</span></td>
                            
                        <td class="border-dark">@(Math.Round(item.ConfidenceScore))%</td>
                            
                        <td class="border-dark"><a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="text-primary text-decoration-underline small">View</a></td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center p-4 text-muted border-dark">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <span>Ви ще не робили жодних перевірок. Перейдіть на вкладку "News Check", щоб почати!</span>
                        }
                        else
                        {
                            <span>Увійдіть у систему, щоб побачити вашу історію.</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<a asp-controller="Home" asp-action="History" class="d-block mt-3 text-primary text-decoration-underline mb-5 small">See more...</a>
</div>