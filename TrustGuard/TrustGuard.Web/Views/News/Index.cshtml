@{
    ViewData["Title"] = "News Check";
}

<div class="row mt-4">
    <div class="col-lg-8">
        
        <form id="analyzeForm" asp-controller="News" asp-action="Analyze" method="post" enctype="multipart/form-data">
    
            <ul class="nav nav-tabs" id="checkTypeTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active text-dark" id="text-tab" data-bs-toggle="tab" data-bs-target="#text-pane" type="button" role="tab">Текст</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-dark" id="url-tab" data-bs-toggle="tab" data-bs-target="#url-pane" type="button" role="tab">URL</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-dark" id="doc-tab" data-bs-toggle="tab" data-bs-target="#doc-pane" type="button" role="tab">Документ</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-dark" id="image-tab" data-bs-toggle="tab" data-bs-target="#image-pane" type="button" role="tab">Зображення</button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-0 mb-4 bg-white" id="myTabContent">
        
                <div class="tab-pane fade show active" id="text-pane" role="tabpanel">
                    <textarea name="textContent" class="form-control border-0 p-3 shadow-none" rows="12" placeholder="Вставте текст новини..."></textarea>
                </div>
        
                <div class="tab-pane fade p-4" id="url-pane" role="tabpanel" style="min-height: 300px;">
                    <label class="form-label text-muted">Вставте посилання на статтю:</label>
                    <input type="url" name="urlContent" class="form-control form-control-lg" placeholder="https://..." />
                </div>
        
                <div class="tab-pane fade p-4" id="doc-pane" role="tabpanel" style="min-height: 300px;">
                    <label class="form-label text-muted">Завантажте текстовий файл (.txt, .pdf, .docx):</label>
                    <input type="file" name="documentFile" class="form-control form-control-lg" accept=".txt,.pdf,.docx" />
                </div>
        
                <div class="tab-pane fade p-4" id="image-pane" role="tabpanel" style="min-height: 300px;">
                    <label class="form-label text-muted">Завантажте фото для перевірки на маніпуляції:</label>
                    <input type="file" name="imageFile" class="form-control form-control-lg" accept="image/*" />
                </div>

            </div>

            <button type="submit" class="btn btn-outline-primary px-5 py-2 fw-bold" style="border-radius: 8px;">
                Аналізувати
            </button>
    
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.Summary))
        {
            <div class="mt-4 p-4 bg-white border shadow-sm text-start" style="border-radius: 12px; border-left: 5px solid #0d6efd !important;">
                <h5 class="fw-bold text-dark mb-3">
                    <i class="bi bi-card-text text-primary me-2"></i>Короткий зміст:
                </h5>
                <p class="mb-0 text-muted" style="font-size: 1rem; line-height: 1.6; white-space: pre-line;">
                    @ViewBag.Summary
                </p>
            </div>
        }

    </div>

    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="d-flex flex-column h-100">
        
            <div class="border bg-white p-4 text-center mb-4 shadow-sm" style="border-radius: 12px; min-height: 450px;">
    
                <div id="panel-content" class="h-100">
                    @if (ViewBag.Verdict != null)
                    {
                        <!-- Блок ML Аналізу -->
                        <p class="text-muted small text-uppercase fw-bold mb-4">ML Аналіз Тексту</p>
                        <div class="d-flex justify-content-center mb-4">
                            <div class="rounded-circle d-flex flex-column align-items-center justify-content-center border border-3 @(ViewBag.Verdict == "Fake" ? "border-danger text-danger" : "border-success text-success")"
                                 style="width: 130px; height: 130px;">
                                <span class="fw-bold h4 mb-0">@ViewBag.Verdict.ToString().ToUpper()</span>
                                <span class="small">@Math.Round(Convert.ToDouble(ViewBag.Confidence))%</span>
                            </div>
                        </div>

                        <!-- НОВИЙ БЛОК: Аналіз джерела (Показується ТІЛЬКИ якщо перевіряли URL) -->
                        @if (ViewBag.DomainScore != null)
                        {
                            <p class="text-muted small text-uppercase fw-bold mb-3 mt-4">Надійність джерела</p>
                            <div class="d-flex flex-column align-items-center mb-4">
                                <div class="rounded-circle d-flex flex-column align-items-center justify-content-center border border-3 border-primary text-primary mb-3"
                                     style="width: 130px; height: 130px;">
                                    <span class="fw-bold h2 mb-0">@ViewBag.DomainScore</span>
                                    <span class="small">зі 100</span>
                                </div>
                                
                                @if (ViewBag.DomainFactors != null)
                                {
                                    <ul class="list-unstyled text-start text-muted small" style="max-width: 250px;">
                                        @foreach (var factor in (List<string>)ViewBag.DomainFactors)
                                        {
                                            <li class="mb-2">@factor</li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    }
                    else if (ViewBag.Error != null)
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center">
                            <i class="bi bi-exclamation-triangle text-danger mb-3" style="font-size: 3rem;"></i>
                            <p class="text-danger text-center px-3">@ViewBag.Error</p>
                        </div>
                    }
                    else
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                            <i class="bi bi-robot mb-3" style="font-size: 4.5rem; opacity: 0.8;"></i>
                            <h5 class="fw-light" style="letter-spacing: 0.5px;">Are you ready?</h5>
                        </div>
                    }
                </div>

                <!-- Мінімалістичний лоадер -->
                <div id="loading-spinner" class="d-none h-100 flex-column align-items-center justify-content-center bg-white" style="border-radius: 12px; min-height: 450px;">
                    <div class="w-75 bg-light" style="height: 3px; border-radius: 2px; overflow: hidden;">
                        <div id="loading-progress-bar" class="bg-primary h-100" style="width: 0%; transition: width 0.1s linear;"></div>
                    </div>
                </div>

            </div>

            <!-- Оновлений блок із посиланнями -->
            @if (ViewBag.OsintLinks != null && ((List<TrustGuard.Application.Interfaces.SourceLink>)ViewBag.OsintLinks).Any())
            {
                var links = (List<TrustGuard.Application.Interfaces.SourceLink>)ViewBag.OsintLinks;
                
                <div class="mt-2">
                    <!-- Змінено заголовок тут -->
                    <h6 class="fw-bold mb-3">Схоже у мережі серед довірених джерел:</h6>
                    <div class="border bg-white p-3 shadow-sm" style="border-radius: 12px;">
                        <ol class="ps-3 mb-2">
                            @for (int i = 0; i < links.Count; i++)
                            {
                                var displayClass = i >= 3 ? "d-none extra-link" : "";
                                
                                <li class="mb-2 small @displayClass">
                                    <a href="@links[i].Url" target="_blank" class="text-primary text-decoration-none d-block text-truncate">
                                        @links[i].Name
                                    </a>
                                </li>
                            }
                        </ol>
                        
                        @if (links.Count > 3)
                        {
                            <button type="button" id="toggle-links-btn" class="btn btn-link text-muted small p-0 text-decoration-none shadow-none" onclick="toggleLinks()">
                                See more...
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function toggleLinks() {
        const extraLinks = document.querySelectorAll('.extra-link');
        const btn = document.getElementById('toggle-links-btn');
        
        let isHidden = extraLinks[0].classList.contains('d-none');
        
        if (isHidden) {
            extraLinks.forEach(link => link.classList.remove('d-none'));
            btn.innerText = "Згорнути";
        } else {
            extraLinks.forEach(link => link.classList.add('d-none'));
            btn.innerText = "See more...";
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById('analyzeForm');
        if (!form) return;

        form.addEventListener('submit', function(e) {
            const submitBtn = form.querySelector('button[type="submit"]');
            
            setTimeout(() => {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Обробка...';
            }, 10);

            const panelContent = document.getElementById('panel-content');
            if (panelContent) {
                panelContent.classList.add('d-none');
                panelContent.classList.remove('d-flex');
            }

            const loader = document.getElementById('loading-spinner');
            if (loader) {
                loader.classList.remove('d-none');
                loader.classList.add('d-flex');
            }

            const progressBar = document.getElementById('loading-progress-bar');
            let currentProgress = 0;

            const progressInterval = setInterval(() => {
                if (currentProgress < 95) {
                    currentProgress += 1;
                    progressBar.style.width = currentProgress + '%';
                } else {
                    clearInterval(progressInterval);
                }
            }, 80);
        });
    });
</script>