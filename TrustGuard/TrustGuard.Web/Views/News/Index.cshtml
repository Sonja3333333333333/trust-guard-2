@{
    ViewData["Title"] = "News Check";
}

<div class="row mt-4">
    <div class="col-lg-8">
        
        <form asp-controller="News" asp-action="Analyze" method="post" enctype="multipart/form-data">
    
            <ul class="nav nav-tabs" id="checkTypeTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active text-dark" id="text-tab" data-bs-toggle="tab" data-bs-target="#text-pane" type="button" role="tab">Текст</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-dark" id="url-tab" data-bs-toggle="tab" data-bs-target="#url-pane" type="button" role="tab">URL</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-dark" id="doc-tab" data-bs-toggle="tab" data-bs-target="#doc-pane" type="button" role="tab">Документ</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-dark" id="image-tab" data-bs-toggle="tab" data-bs-target="#image-pane" type="button" role="tab">Зображення</button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-0 mb-4 bg-white" id="myTabContent">
        
                <div class="tab-pane fade show active" id="text-pane" role="tabpanel">
                    <textarea name="textContent" class="form-control border-0 p-3 shadow-none" rows="12" placeholder="Вставте текст новини..."></textarea>
                </div>
        
                <div class="tab-pane fade p-4" id="url-pane" role="tabpanel" style="min-height: 300px;">
                    <label class="form-label text-muted">Вставте посилання на статтю:</label>
                    <input type="url" name="urlContent" class="form-control form-control-lg" placeholder="https://..." />
                </div>
        
                <div class="tab-pane fade p-4" id="doc-pane" role="tabpanel" style="min-height: 300px;">
                    <label class="form-label text-muted">Завантажте текстовий файл (.txt, .pdf, .docx):</label>
                    <input type="file" name="documentFile" class="form-control form-control-lg" accept=".txt,.pdf,.docx" />
                </div>
        
                <div class="tab-pane fade p-4" id="image-pane" role="tabpanel" style="min-height: 300px;">
                    <label class="form-label text-muted">Завантажте фото для перевірки на маніпуляції:</label>
                    <input type="file" name="imageFile" class="form-control form-control-lg" accept="image/*" />
                </div>

            </div>

            <button type="submit" class="btn btn-outline-primary px-5 py-2 fw-bold" style="border-radius: 8px;">
                Аналізувати
            </button>
    
        </form>

    </div>

    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="d-flex flex-column h-100">
        
            <div class="border bg-white p-4 text-center mb-4 shadow-sm" style="border-radius: 12px; min-height: 450px;">
            
                @if (ViewBag.Verdict != null)
                {
                    <p class="text-muted small text-uppercase fw-bold mb-4">ML Аналіз</p>

                    <div class="d-flex justify-content-center mb-4">
                        <div class="rounded-circle d-flex flex-column align-items-center justify-content-center border border-3 @(ViewBag.Verdict == "Fake" ? "border-danger text-danger" : "border-success text-success")"
                             style="width: 130px; height: 130px;">
                            <span class="fw-bold h4 mb-0">@ViewBag.Verdict.ToString().ToUpper()</span>
                            <span class="small">@Math.Round(Convert.ToDouble(ViewBag.Confidence))%</span>
                        </div>
                    </div>

                    <p class="text-muted small text-uppercase fw-bold mb-3">Підтвердження джерел</p>

                    <div class="d-flex justify-content-center mb-4">
                        @{
                            var osintStatus = ViewBag.OsintStatus?.ToString();
                            var osintColor = osintStatus == "Confirmed" ? "border-success text-success" : "border-warning text-warning";
                            var osintText = osintStatus == "Confirmed" ? "TRUE" : "CHECK";
                        }
                        <div class="rounded-circle d-flex flex-column align-items-center justify-content-center border border-3 @osintColor"
                             style="width: 130px; height: 130px;">
                            <span class="fw-bold h4 mb-0">@osintText</span>
                            <span class="small">OSINT</span>
                        </div>
                    </div>

                    <div class="alert alert-light border d-flex align-items-center justify-content-start py-2 px-3 mt-auto" style="border-radius: 8px;">
                        <i class="bi bi-info-circle me-2"></i>
                        <span class="small text-dark">
                            @if (ViewBag.OsintStatus == "Confirmed")
                            {
                                @:Знайдено згадки (@(ViewBag.OsintLinks?.Count ?? 0)+)
                            }
                            else
                            {
                                @:Джерел не знайдено
                            }
                        </span>
                    </div>
                }
                else if (ViewBag.Error != null)
                {
                    <div class="h-100 d-flex flex-column align-items-center justify-content-center">
                        <i class="bi bi-exclamation-triangle text-danger mb-3" style="font-size: 3rem;"></i>
                        <p class="text-danger text-center px-3">@ViewBag.Error</p>
                    </div>
                }
                else
                {
                    <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                        <i class="bi bi-cpu mb-3" style="font-size: 4rem;"></i>
                        <h5 class="fw-light">Чекаю на дані...</h5>
                    </div>
                }
            </div>

            @if (ViewBag.OsintLinks != null && ((List<TrustGuard.Application.Interfaces.SourceLink>)ViewBag.OsintLinks).Any())
            {
                <div class="mt-2">
                    <h6 class="fw-bold mb-3">Схоже у Google News</h6>
                    <div class="border bg-white p-3 shadow-sm" style="border-radius: 12px;">
                        <ol class="ps-3 mb-2">
                            @foreach (var link in (List<TrustGuard.Application.Interfaces.SourceLink>)ViewBag.OsintLinks)
                            {
                                <li class="mb-2 small">
                                    <a href="@link.Url" target="_blank" class="text-primary text-decoration-none d-block" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @link.Name
                                    </a>
                                </li>
                            }
                        </ol>
                        <a href="https://news.google.com" target="_blank" class="text-muted small text-decoration-none">See more...</a>
                    </div>
                </div>
            }
        </div>
    </div>
    </div>
</div>